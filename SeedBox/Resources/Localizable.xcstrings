    "Turn on update checks in Settings to check for mod updates.": {
      "comment": "Status message for the mod update checking feature.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere die Update-Suche in den Einstellungen, um nach Mod-Updates zu suchen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on update checks in Settings to check for mod updates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa la búsqueda de actualizaciones en Ajustes para buscar actualizaciones de mods."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez la recherche de mises à jour dans Réglages pour rechercher les mises à jour des mods."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva i controlli degli aggiornamenti nelle Impostazioni per cercare aggiornamenti delle mod."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MODのアップデートを確認するには、設定でアップデート確認をオンにしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모드 업데이트를 확인하려면 설정에서 업데이트 확인을 켜세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel updatecontroles in bij Instellingen om op mod-updates te controleren."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative a verificação de atualizações em Ajustes para verificar atualizações de mods."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在设置中开启更新检查以检查模组更新。"
          }
        }
      }
    },
    "Turn on update checks in Settings to compare your installed mods against smapi.io. Available updates appear in the Updates column and in each mod's details.": {
      "comment": "Help window content. smapi.io is a service name; keep it as is.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktiviere die Update-Suche in den Einstellungen, um deine installierten Mods mit smapi.io zu vergleichen. Verfügbare Updates erscheinen in der Spalte „Updates“ und in den Details jeder Mod."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turn on update checks in Settings to compare your installed mods against smapi.io. Available updates appear in the Updates column and in each mod's details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa la búsqueda de actualizaciones en Ajustes para comparar tus mods instalados con smapi.io. Las actualizaciones disponibles aparecen en la columna Actualizaciones y en los detalles de cada mod."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez la recherche de mises à jour dans Réglages pour comparer vos mods installés avec smapi.io. Les mises à jour disponibles apparaissent dans la colonne Mises à jour et dans les détails de chaque mod."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva i controlli degli aggiornamenti nelle Impostazioni per confrontare le mod installate con smapi.io. Gli aggiornamenti disponibili compaiono nella colonna Aggiornamenti e nei dettagli di ogni mod."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定でアップデート確認をオンにすると、インストール済みMODをsmapi.ioと比較します。利用可能なアップデートは「アップデート」列と各MODの詳細に表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정에서 업데이트 확인을 켜면 설치된 모드를 smapi.io와 비교합니다. 사용 가능한 업데이트는 업데이트 열과 각 모드의 세부 정보에 표시됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel updatecontroles in bij Instellingen om je geïnstalleerde mods met smapi.io te vergelijken. Beschikbare updates verschijnen in de kolom Updates en in de details van elke mod."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative a verificação de atualizações em Ajustes para comparar seus mods instalados com o smapi.io. Atualizações disponíveis aparecem na coluna Atualizações e nos detalhes de cada mod."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在设置中开启更新检查，即可将已安装的模组与 smapi.io 进行比较。可用更新会显示在“更新”列和每个模组的详细信息中。"
          }
        }
      }
    },
