    "A mod already exists at %@.": {
      "comment": "Dynamic user-visible string. %@ placeholders are app-provided names, paths, or descriptions; keep placeholders intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Mod existiert bereits bei %1$@."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A mod already exists at %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya existe un mod en %1$@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un mod existe déjà chez %1$@."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esiste già una mod su %1$@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MOD は %1$@ にすでに存在します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@에 모드가 이미 존재합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er bestaat al een mod op %1$@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Já existe um mod em %1$@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 上已经存在一个模组。"
          }
        }
      }
    },
    "A mod set named %@ already exists.": {
      "comment": "Mod set status message. %@ placeholders are mod set names, mod names, or localized details; keep placeholders intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Mod-Set namens %1$@ existiert bereits."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A mod set named %@ already exists."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ya existe un conjunto de mods llamado %1$@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un ensemble de mods nommé %1$@ existe déjà."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esiste già un set di modifiche denominato %1$@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ という名前の MOD セットはすでに存在します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@라는 모드 세트가 이미 존재합니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er bestaat al een modset met de naam %1$@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Já existe um conjunto de mods chamado %1$@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "名为 %1$@ 的模组集已存在。"
          }
        }
      }
    },
    "A mod set remembers which mods are enabled. Switch sets to swap loadouts before launching the game; changes made while a custom set is active are saved back into it.": {
      "comment": "Help window content.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Mod-Set merkt sich, welche Mods aktiviert sind. Wechsle Sets, um vor dem Spielstart die Ausstattung zu tauschen; Änderungen bei aktivem eigenem Set werden darin gespeichert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A mod set remembers which mods are enabled. Switch sets to swap loadouts before launching the game; changes made while a custom set is active are saved back into it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un conjunto de mods recuerda qué mods están habilitados. Cambia de conjunto para alternar configuraciones antes de iniciar el juego; los cambios hechos con un conjunto personalizado activo se guardan en él."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un ensemble de mods mémorise quels mods sont activés. Changez d'ensemble pour échanger de configuration avant de lancer le jeu ; les changements faits avec un ensemble personnalisé actif y sont enregistrés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un set di mod ricorda quali mod sono abilitate. Cambia set per alternare configurazioni prima di avviare il gioco; le modifiche fatte con un set personalizzato attivo vengono salvate al suo interno."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MODセットはどのMODが有効かを記憶します。ゲーム起動前にセットを切り替えて構成を入れ替えられます。カスタムセットが有効な間の変更はそのセットに保存されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모드 세트는 어떤 모드가 활성화되어 있는지 기억합니다. 게임 시작 전에 세트를 전환해 구성을 바꿔보세요. 사용자 세트가 활성화된 동안의 변경은 해당 세트에 저장됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een modset onthoudt welke mods zijn ingeschakeld. Wissel van set om vóór het starten van het spel van samenstelling te wisselen; wijzigingen met een actieve eigen set worden erin opgeslagen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um conjunto de mods lembra quais mods estão ativados. Troque de conjunto para alternar configurações antes de iniciar o jogo; mudanças feitas com um conjunto personalizado ativo são salvas nele."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模组合集会记住哪些模组处于启用状态。启动游戏前切换合集即可更换配置；自定义合集处于活动状态时所做的更改会保存回该合集。"
          }
        }
      }
    },
