    "Found a bug or need help? Report it on GitHub and describe what you were doing when it happened.": {
      "comment": "Help window content. GitHub is a service name; keep it as is.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fehler gefunden oder Hilfe nötig? Melde es auf GitHub und beschreibe, was du gerade gemacht hast."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Found a bug or need help? Report it on GitHub and describe what you were doing when it happened."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Encontraste un error o necesitas ayuda? Infórmalo en GitHub y describe qué estabas haciendo cuando ocurrió."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un bug ou besoin d'aide ? Signalez-le sur GitHub en décrivant ce que vous faisiez au moment du problème."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai trovato un bug o ti serve aiuto? Segnalalo su GitHub descrivendo cosa stavi facendo quando è successo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バグを見つけた、または助けが必要ですか？GitHubで報告し、問題発生時に何をしていたかを記載してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "버그를 발견했거나 도움이 필요하신가요? GitHub에 보고하고 문제가 발생했을 때 무엇을 하고 있었는지 설명해 주세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Een fout gevonden of hulp nodig? Meld het op GitHub en beschrijf wat je deed toen het gebeurde."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontrou um bug ou precisa de ajuda? Relate no GitHub e descreva o que você estava fazendo quando aconteceu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发现了 bug 或需要帮助？请在 GitHub 上报告，并描述问题发生时你正在进行的操作。"
          }
        }
      }
    },
