    "Couldn't carry settings forward for %@; the previous settings remain in the archive.": {
      "comment": "Warning appended to the install status when a mod's config.json couldn't be copied into its updated copy. %@ is a comma-separated list of mod names; keep it intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Einstellungen für %1$@ konnten nicht übernommen werden; die bisherigen Einstellungen bleiben im Archiv erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't carry settings forward for %1$@; the previous settings remain in the archive."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudieron transferir los ajustes de %1$@; los ajustes anteriores permanecen en el archivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de transférer les réglages de %1$@ ; les réglages précédents restent dans l'archive."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile trasferire le impostazioni di %1$@; le impostazioni precedenti restano nell'archivio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@の設定を引き継げませんでした。以前の設定はアーカイブに残っています。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@의 설정을 이어받지 못했습니다. 이전 설정은 보관함에 남아 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan de instellingen voor %1$@ niet overnemen; de vorige instellingen blijven in het archief."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível transferir as configurações de %1$@; as configurações anteriores permanecem no arquivo."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法为 %1$@ 保留设置；先前的设置仍保留在归档中。"
          }
        }
      }
    },
