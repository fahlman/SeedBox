    "Identified %@ as the likely problem. It was left disabled and your other mods were restored.": {
      "comment": "Status message when the problem-mod search finds the culprit. %@ is the mod name; keep it intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ wurde als wahrscheinliches Problem identifiziert, bleibt deaktiviert; die übrigen Mods wurden wiederhergestellt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Identified %1$@ as the likely problem. It was left disabled and your other mods were restored."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se identificó %1$@ como el problema probable. Se dejó desactivado y el resto de tus mods se restauraron."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ a été identifié comme problème probable. Il reste désactivé et vos autres mods ont été restaurés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ è stata identificata come probabile problema. È rimasta disattivata e le altre mod sono state ripristinate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@が問題の原因と特定されました。無効のままにし、他のMODは復元されました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@가 문제의 원인으로 확인되었습니다. 비활성화된 상태로 두고 다른 모드는 복원했습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ is geïdentificeerd als het waarschijnlijke probleem. Deze blijft uitgeschakeld en je overige mods zijn hersteld."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ foi identificado como o provável problema. Ele permaneceu desativado e seus outros mods foram restaurados."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已确定 %1$@ 可能是问题所在。它保持停用状态，其他模组已恢复。"
          }
        }
      }
    },
    "Included mod set names cannot be changed.": {
      "comment": "Message about a saved mod set, a group of enabled and disabled mods.",
      "localizations": {
        "de": {
          "stringUnit": {
