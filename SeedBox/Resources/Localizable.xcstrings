    "Apply Anyway": {
      "comment": "Alert button. Applies a mod set despite dependency warnings.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bewerben Sie sich trotzdem"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply Anyway"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicar de todos modos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Postuler quand même"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Candidati comunque"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "とにかく応募する"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어쨌든 신청하세요"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoe dan ook solliciteren"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Inscreva-se mesmo assim"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无论如何申请"
          }
        }
      }
    },
    "Applying %@ will leave %@ with unresolved dependencies: %@. Apply anyway?": {
      "comment": "Dependency warning. %@ placeholders are mod names or localized dependency summaries; keep placeholders intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch die Anwendung von %1$@ bleiben %2$@ mit ungelösten Abhängigkeiten zurück: %3$@. Trotzdem bewerben?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Applying %1$@ will leave %2$@ with unresolved dependencies: %3$@. Apply anyway?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La aplicación de %1$@ dejará a %2$@ con dependencias sin resolver: %3$@. ¿Aplicar de todos modos?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'application de %1$@ laissera %2$@ avec des dépendances non résolues : %3$@. Postuler quand même ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'applicazione di %1$@ lascerà %2$@ con dipendenze irrisolte: %3$@. Candidarsi comunque?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ を適用すると、%2$@ には未解決の依存関係 (%3$@) が残ります。とにかく応募しますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@를 적용하면 %2$@에 해결되지 않은 종속성(%3$@)이 남게 됩니다. 그래도 신청하시겠습니까?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als u %1$@ toepast, blijft %2$@ achter met onopgeloste afhankelijkheden: %3$@. Toch solliciteren?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A aplicação do %1$@ deixará o %2$@ com dependências não resolvidas: %3$@. Aplicar mesmo assim?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用 %1$@ 将使 %2$@ 具有未解决的依赖关系：%3$@。还是申请吧？"
          }
        }
      }
    },
    "Applying %@ will leave %lld mods with missing required dependencies. Apply anyway?\n\n%@": {
      "comment": "Count-based user-visible string. %lld is the mod count; keep placeholders intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch die Anwendung von %1$@ verbleiben %2$lld Mods mit fehlenden erforderlichen Abhängigkeiten. Trotzdem bewerben?\n\n%3$@"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Applying %1$@ will leave %2$lld mods with missing required dependencies. Apply anyway?\n\n%3$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La aplicación de %1$@ dejará a los mods %2$lld sin las dependencias requeridas. ¿Aplicar de todos modos?\n\n%3$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'application de %1$@ laissera les mods %2$lld avec les dépendances requises manquantes. Postuler quand même ?\n\n%3$@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'applicazione di %1$@ lascerà le mod %2$lld con le dipendenze richieste mancanti. Candidarsi comunque?\n\n%3$@"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ を適用すると、必要な依存関係が欠落した %2$lld MOD が残ります。とにかく応募しますか？\n\n%3$@"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@를 적용하면 %2$lld 모드에 필수 종속성이 누락됩니다. 그래도 신청하시겠습니까?\n\n%3$@"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als u %1$@ toepast, blijven %2$lld-mods achter met ontbrekende vereiste afhankelijkheden. Toch solliciteren?\n\n%3$@"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A aplicação de %1$@ deixará os mods %2$lld sem dependências necessárias. Aplicar mesmo assim?\n\n%3$@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用 %1$@ 将使 %2$lld mods 缺少所需的依赖项。还是申请吧？\n\n%3$@"
          }
        }
      }
    },
