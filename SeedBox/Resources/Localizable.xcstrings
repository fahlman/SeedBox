    "Skipped %@ because it was duplicated in the selected sources.": {
      "comment": "Dynamic user-visible string. %@ placeholders are app-provided names, paths, or descriptions; keep placeholders intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ wurde übersprungen, da es in den ausgewählten Quellen dupliziert wurde."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skipped %@ because it was duplicated in the selected sources."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se omitió %1$@ porque estaba duplicado en las fuentes seleccionadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ ignoré car il était dupliqué dans les sources sélectionnées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ saltato perché duplicato nelle sorgenti selezionate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ は選択したソースで重複しているためスキップされました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 소스에서 중복되었기 때문에 %1$@를 건너뛰었습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ overgeslagen omdat het werd gedupliceerd in de geselecteerde bronnen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ ignorado porque foi duplicado nas fontes selecionadas."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跳过 %1$@，因为它在所选源中重复。"
          }
        }
      }
    },
