    "Couldn't extract %@ because it contains more than %lld files.": {
      "comment": "Error shown when a ZIP archive is rejected for safety. %@ is the archive file name, %lld is the maximum allowed file count; keep both intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ konnte nicht entpackt werden, weil es mehr als %2$lld Dateien enthält."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't extract %1$@ because it contains more than %2$lld files."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo extraer %1$@ porque contiene más de %2$lld archivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible d'extraire %1$@ car il contient plus de %2$lld fichiers."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile estrarre %1$@ perché contiene più di %2$lld file."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@には%2$lld個を超えるファイルが含まれているため、展開できませんでした。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@에 %2$lld개가 넘는 파일이 들어 있어 압축을 풀 수 없습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan %1$@ niet uitpakken omdat het meer dan %2$lld bestanden bevat."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível extrair %1$@ porque contém mais de %2$lld arquivos."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法解压 %1$@，因为它包含超过 %2$lld 个文件。"
          }
        }
      }
    },
    "Couldn't extract %@ because it expands to more than %@.": {
      "comment": "Error shown when a ZIP archive is rejected for safety. First %@ is the archive file name, second %@ is a formatted size limit such as 4 GB; keep both intact.",
      "localizations": {
        "de": {
