    "%@ requires %@, which are not ready. Would you like to enable %@ anyway?": {
      "comment": "Dependency warning. %@ placeholders are mod names or localized dependency summaries; keep placeholders intact.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ erfordert %2$@, die nicht bereit sind. Möchten Sie %3$@ trotzdem aktivieren?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ requires %2$@, which are not ready. Would you like to enable %3$@ anyway?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ requiere %2$@, que no están listos. ¿Le gustaría habilitar %3$@ de todos modos?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ nécessite %2$@, qui n'est pas prêt. Souhaitez-vous quand même activer %3$@ ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ richiede %2$@, che non è pronto. Desideri abilitare comunque %3$@?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ には %2$@ が必要ですが、これは準備ができていません。とにかく %3$@ を有効にしますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@에는 아직 준비되지 않은 %2$@가 필요합니다. 어쨌든 %3$@를 활성화하시겠습니까?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ vereist %2$@, die nog niet gereed zijn. Wilt u %3$@ toch inschakelen?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ requer %2$@, que não está pronto. Você gostaria de ativar o %3$@ mesmo assim?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ 需要 %2$@，但 %2$@ 尚未准备好。您仍然想启用 %3$@ 吗？"
          }
        }
      }
    },
