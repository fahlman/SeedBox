    "Checks send each mod's unique ID, version, and update keys to smapi.io.": {
      "comment": "Privacy explanation shown under the update check toggle in Settings. smapi.io is a service name; keep it as is.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei der Suche werden die eindeutige ID, Version und Update-Schlüssel jeder Mod an smapi.io gesendet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Checks send each mod's unique ID, version, and update keys to smapi.io."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las comprobaciones envían el ID único, la versión y las claves de actualización de cada mod a smapi.io."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les vérifications envoient l'ID unique, la version et les clés de mise à jour de chaque mod à smapi.io."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I controlli inviano l'ID univoco, la versione e le chiavi di aggiornamento di ogni mod a smapi.io."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "確認時には各MODの固有ID、バージョン、アップデートキーがsmapi.ioに送信されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확인 시 각 모드의 고유 ID, 버전, 업데이트 키가 smapi.io로 전송됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bij controles worden de unieke ID, versie en update-sleutels van elke mod naar smapi.io gestuurd."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As verificações enviam o ID exclusivo, a versão e as chaves de atualização de cada mod para smapi.io."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "检查时会将每个模组的唯一 ID、版本和更新密钥发送到 smapi.io。"
