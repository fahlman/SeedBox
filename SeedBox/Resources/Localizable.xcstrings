          "stringUnit": {
            "state": "translated",
            "value": "Das Problem stammt von einer dieser Mods: %1$@. Deine Mods wurden wiederhergestellt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The problem comes from one of: %1$@. Your mods were restored."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El problema proviene de uno de estos: %1$@. Tus mods se restauraron."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le problème provient de l'un de ces mods : %1$@. Vos mods ont été restaurés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il problema proviene da una di queste mod: %1$@. Le tue mod sono state ripristinate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "問題は次のいずれかにあります：%1$@。MODは復元されました。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "문제는 다음 중 하나에서 발생합니다: %1$@. 모드가 복원되었습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het probleem komt van een van deze mods: %1$@. Je mods zijn hersteld."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O problema vem de um destes: %1$@. Seus mods foram restaurados."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "问题来自以下模组之一：%1$@。模组已恢复。"
          }
        }
      }
    },
    "This folder is a link to another location, so Seed Box doesn't manage it.": {
      "comment": "Reason shown in the Problems list when an entry in the Mods folder is a symbolic link rather than a real folder.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Ordner ist eine Verknüpfung zu einem anderen Ort, daher verwaltet Seed Box ihn nicht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This folder is a link to another location, so Seed Box doesn't manage it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta carpeta es un enlace a otra ubicación, por lo que Seed Box no la gestiona."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce dossier est un lien vers un autre emplacement, Seed Box ne le gère donc pas."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa cartella è un collegamento a un'altra posizione, quindi Seed Box non la gestisce."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このフォルダは別の場所へのリンクのため、Seed Boxでは管理されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 폴더는 다른 위치로 연결되는 링크이므로 Seed Box에서 관리하지 않습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze map is een koppeling naar een andere locatie, dus Seed Box beheert deze niet."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta pasta é um link para outro local, então o Seed Box não a gerencia."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此文件夹是指向其他位置的链接，因此 Seed Box 不管理它。"
          }
        }
      }
    },
