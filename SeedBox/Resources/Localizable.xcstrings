          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer %1$@ ? Une copie restaurable sera archivée pendant %2$lld jours."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminare %1$@? Una copia ripristinabile verrà archiviata per %2$lld giorni."
          }
        },
        "ja": {
          "stringUnit": {
