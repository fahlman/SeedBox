    "Seed Box reads SMAPI's log to show what happened in your last game session. The usual location is ~/.config/StardewValley/ErrorLogs.": {
      "comment": "Explanation under the SMAPI Log section in Settings. Keep the path ~/.config/StardewValley/ErrorLogs as is.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed Box liest das SMAPI-Protokoll, um zu zeigen, was in deiner letzten Spielsitzung passiert ist. Der übliche Speicherort ist ~/.config/StardewValley/ErrorLogs."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed Box reads SMAPI's log to show what happened in your last game session. The usual location is ~/.config/StardewValley/ErrorLogs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed Box lee el registro de SMAPI para mostrar lo que ocurrió en tu última sesión de juego. La ubicación habitual es ~/.config/StardewValley/ErrorLogs."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed Box lit le journal de SMAPI pour montrer ce qui s'est passé lors de votre dernière session de jeu. L'emplacement habituel est ~/.config/StardewValley/ErrorLogs."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed Box legge il registro di SMAPI per mostrare cosa è successo nell'ultima sessione di gioco. La posizione abituale è ~/.config/StardewValley/ErrorLogs."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed BoxはSMAPIのログを読み取り、前回のゲームセッションで何が起きたかを表示します。通常の場所は ~/.config/StardewValley/ErrorLogs です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed Box는 SMAPI 로그를 읽어 마지막 게임 세션에서 일어난 일을 보여줍니다. 일반적인 위치는 ~/.config/StardewValley/ErrorLogs입니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed Box leest het SMAPI-logboek om te tonen wat er in je laatste spelsessie is gebeurd. De gebruikelijke locatie is ~/.config/StardewValley/ErrorLogs."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Seed Box lê o registro do SMAPI para mostrar o que aconteceu na sua última sessão de jogo. O local habitual é ~/.config/StardewValley/ErrorLogs."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Seed Box 会读取 SMAPI 的日志，以显示上次游戏会话中发生的情况。通常位置为 ~/.config/StardewValley/ErrorLogs。"
          }
        }
      }
    },
