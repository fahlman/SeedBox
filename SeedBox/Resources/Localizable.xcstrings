          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile estrarre %1$@ perché si espande oltre %2$@."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@は展開すると%2$@を超えるため、展開できませんでした。"
