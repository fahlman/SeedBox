    "%@ requires %@, which are not ready. Would you like to enable %@ anyway?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ requires %2$@, which are not ready. Would you like to enable %3$@ anyway?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ erfordert %2$@, die nicht bereit sind. Möchten Sie %3$@ trotzdem aktivieren?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ requiere %2$@, que no están listos. ¿Le gustaría habilitar %3$@ de todos modos?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ nécessite %2$@, qui n'est pas prêt. Souhaitez-vous quand même activer %3$@ ?"
