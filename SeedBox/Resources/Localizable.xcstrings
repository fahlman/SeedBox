    "%@ is required by %@. Would you like to disable %@ anyway?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@ is required by %2$@. Would you like to disable %3$@ anyway?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ wird von %2$@ benötigt. Möchten Sie %3$@ trotzdem deaktivieren?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ es requerido por %2$@. ¿Le gustaría desactivar %3$@ de todos modos?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ est requis par %2$@. Souhaitez-vous quand même désactiver %3$@ ?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ è richiesto da %2$@. Desideri comunque disattivare %3$@?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$@ には %1$@ が必要です。とにかく %3$@ を無効にしますか?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$@에는 %1$@가 필요합니다. 어쨌든 %3$@를 비활성화하시겠습니까?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ is vereist voor %2$@. Wilt u %3$@ toch uitschakelen?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ é exigido pelo %2$@. Você gostaria de desativar o %3$@ mesmo assim?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%2$@ 需要 %1$@。您仍然想禁用 %3$@ 吗？"
          }
        }
      },
      "comment": "Dependency warning. %@ placeholders are mod names or localized dependency summaries; keep placeholders intact."
    },
