          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kan %1$@ niet uitpakken omdat het uitpakt tot meer dan %2$@."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível extrair %1$@ porque ele se expande para mais de %2$@."
          }
        },
